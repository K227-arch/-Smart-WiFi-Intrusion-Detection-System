{
  "name": "salamanda-wids",
  "private": true,
  "version": "2.0.0",
  "description": "Smart WiFi Intrusion Detection System",
  "author": "SALAMANDA Team",
  "type": "module",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:capture": "bash scripts/setup-capture.sh 2>/dev/null || bash scripts/setup-capture-linux.sh 2>/dev/null || true && tsx server.ts",
    "setup:capture": "sudo bash scripts/setup-capture.sh",
    "setup:capture:linux": "sudo bash scripts/setup-capture-linux.sh",
    "build": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --external:cap --external:onnxruntime-node --external:vite --sourcemap --outfile=dist/server.cjs",
    "build:electron": "tsc --project electron/tsconfig.json",
    "build:all": "npm run build && npm run build:server && npm run build:electron",
    "electron:dev": "npm run build:electron && concurrently -k \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build:mac": "npm run build:all && electron-builder --mac",
    "electron:build:win": "npm run build:all && electron-builder --win",
    "electron:build:linux": "npm run build:all && electron-builder --linux",
    "cap:init": "cap init",
    "cap:sync": "npm run build && npx cap sync",
    "cap:ios": "npm run build && npx cap sync ios && npx cap open ios",
    "cap:android": "npm run build && npx cap sync android && npx cap open android",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist electron/dist server.js",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.salamanda.wids",
    "productName": "SALAMANDA WIDS",
    "copyright": "© 2026 SALAMANDA",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/dist/**/*",
      "models/**/*",
      "data/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "models", "to": "models" },
      { "from": "data", "to": "data" }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "icon": "public/icon.icns",
      "hardenedRuntime": true,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "public/icon.ico"
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm"],
      "icon": "public/icon.png",
      "category": "Network"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico"
    }
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@insforge/sdk": "^1.2.9",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-is": "^19.2.7",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/electron": "^1.6.10",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "docx": "^9.7.1",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wait-on": "^8.0.0"
  },
  "optionalDependencies": {
    "cap": "^0.2.1",
    "onnxruntime-node": "^1.20.1"
  }
}
